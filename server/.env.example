# Kokoro VPN Server Configuration
DATABASE_URL=sqlite:kokoro-vpn.db
JWT_SECRET=change-this-to-a-random-secret-string
SERVER_HOST=0.0.0.0
SERVER_PORT=3000

# WireGuard
WG_INTERFACE=wg0
WG_ENDPOINT=vpn.example.org
WG_PORT=51820
WG_SUBNET=10.8.0
WG_DNS=1.1.1.1,8.8.8.8
WG_SERVER_PRIVATE_KEY=
WG_SERVER_PUBLIC_KEY=
WG_CONFIG_DIR=/etc/wireguard

# Admin account (created on first run)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Guest/sandbox settings
GUEST_EXPIRY_MINUTES=30
GUEST_BANDWIDTH_BYTES=104857600
