# ===========================================
# Kokoro VPN Configuration
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ---- WireGuard Settings ----
# Your server's public IP or domain name
WG_HOST=vpn.example.org

# Password for the web management UI
PASSWORD=changeme_use_a_strong_password

# VPN subnet (default is fine for most setups)
WG_DEFAULT_ADDRESS=10.8.0.x

# DNS servers for VPN clients
WG_DEFAULT_DNS=1.1.1.1,8.8.8.8

# WireGuard listening port
WG_PORT=51820

# Allowed IPs for clients (0.0.0.0/0 = route all traffic through VPN)
WG_ALLOWED_IPS=0.0.0.0/0,::/0

# ---- Web UI Settings ----
# Port for the management web interface
UI_PORT=51821

# ---- Optional: Let's Encrypt SSL ----
# Uncomment to enable HTTPS on the web UI via Caddy
# DOMAIN=vpn.example.org
# EMAIL=admin@example.org
